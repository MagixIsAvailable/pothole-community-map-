# Pothole Community Map — Environment Variables
# Copy to .env and fill in values

# API
APP_NAME=pothole-community-map
DEBUG=true
API_HOST=127.0.0.1
API_PORT=8000

# Database (SQLite for local dev)
DATABASE_URL=sqlite:///./pothole_map.db

# Upload limits
MAX_UPLOAD_SIZE_MB=50

# ML
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.35
YOLO_IMAGE_SIZE=640

# Geo-tagging
DEFAULT_LAT=51.5074
DEFAULT_LNG=-0.1278
CLUSTER_EPS_METERS=15
CLUSTER_MIN_SAMPLES=2

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173
